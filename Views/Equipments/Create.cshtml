@model FacilityMaintenanceApp.Models.Equipment

@{
    ViewData["Title"] = "設備登録";
}

<h1>設備登録</h1>

<p class="text-muted">
    新しく管理対象とする設備情報を登録します。
</p>

<hr />

<div class="row">
    <div class="col-md-6">
        @*
            設備情報の新規登録フォーム。
            入力された内容はEquipmentsControllerのCreateアクションに送信される。
        *@
        <form asp-action="Create" method="post">
            @* Model全体に関する入力エラーを表示する。 *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* 設備名。管理対象を識別するための必須項目。 *@
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" placeholder="例：空調設備 A-101" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            @* 設置場所。どこにある設備かを管理するために使用する。 *@
            <div class="form-group mb-3">
                <label asp-for="Location" class="control-label"></label>
                <input asp-for="Location" class="form-control" placeholder="例：1階 事務室" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            @* 設備種別。検索や分類に使うための項目。 *@
            <div class="form-group mb-3">
                <label asp-for="Category" class="control-label"></label>
                <input asp-for="Category" class="form-control" placeholder="例：空調・照明・防災・給排水" />
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            @*
                設備状態。
                自由入力にすると表記ゆれが起きやすいため、プルダウンで選択できるようにしている。
            *@
            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="正常">正常</option>
                    <option value="要対応">要対応</option>
                    <option value="故障">故障</option>
                    <option value="対応中">対応中</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            @*
                次回点検日。
                一覧画面やダッシュボードで、期限超過・7日以内の点検予定を判定するために使用する。
            *@
            <div class="form-group mb-3">
                <label asp-for="NextInspectionDate" class="control-label"></label>
                <input asp-for="NextInspectionDate" class="form-control" type="date" />
                <span asp-validation-for="NextInspectionDate" class="text-danger"></span>
            </div>

            @* 補足情報。設備に関するメモを入力できるようにする。 *@
            <div class="form-group mb-3">
                <label asp-for="Memo" class="control-label"></label>
                <textarea asp-for="Memo" class="form-control" rows="3" placeholder="例：月次点検対象"></textarea>
                <span asp-validation-for="Memo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="登録" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">一覧へ戻る</a>
            </div>
        </form>
    </div>
</div>

@* クライアント側の入力チェックを有効にする。 *@
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}